# ─── Copy this file to .env and fill in values ────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quantdesk
POSTGRES_USER=quantdesk
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20
DATABASE_URL=postgresql://quantdesk:REPLACE_WITH_DB_PASSWORD@localhost:5432/quantdesk

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_URL=redis://localhost:6379

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=quantdesk_chat
MONGO_USER=quantdesk
MONGO_PASSWORD=REPLACE_WITH_MONGO_PASSWORD
MONGO_URL=mongodb://quantdesk:REPLACE_WITH_MONGO_PASSWORD@localhost:27017/quantdesk_chat?authSource=admin

# Firebase Auth (server-side Admin SDK)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=REPLACE_WITH_FIREBASE_PRIVATE_KEY

# Object Storage (Cloudflare R2 or AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=REPLACE_WITH_S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=REPLACE_WITH_S3_SECRET_ACCESS_KEY
S3_BUCKET=quantdesk-docs
S3_REGION=us-east-1

# App
NODE_ENV=development
API_PORT=3001
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_JWT_SECRET
CORS_ORIGIN=http://localhost:5173

# Admin Security — MFA Encryption
# 32-byte AES-256 key for encrypting admin MFA (TOTP) secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — server will exit(1) at startup if missing or default is used.
ADMIN_MFA_KEY=REPLACE_WITH_32_BYTE_HEX_KEY
